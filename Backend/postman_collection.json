{
  "info": {
    "name": "GyaanSetu API",
    "description": "API Documentation for GyaanSetu Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/signup",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    // Store token automatically",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/auth/profile",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/forgot-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/reset-password/YOUR_RESET_TOKEN",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User (Me)",
      "item": [
        {
          "name": "Get My Courses",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/me/courses"
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{token}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "Enroll User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/enroll/YOUR_COURSE_ID"
          }
        },
        {
          "name": "My Enrollments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/enroll/my"
          }
        },
        {
          "name": "Enrollment Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/enroll/status/YOUR_COURSE_ID"
          }
        },
        {
          "name": "Update Progress",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/enroll/progress/YOUR_COURSE_ID",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"progress\": 50\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{token}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/users"
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/users/YOUR_USER_ID/role",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/users/YOUR_USER_ID"
          }
        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/courses",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Admin Course\",\n  \"description\": \"Course Description\"\n}"
            }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/courses/YOUR_COURSE_ID",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Course Title\"\n}"
            }
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/courses/YOUR_COURSE_ID"
          }
        },
        {
          "name": "Update Modules",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/courses/YOUR_COURSE_ID/modules",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"modules\": []\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{token}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Public API",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/courses"
          }
        },
        {
          "name": "Get Course By ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/courses/YOUR_COURSE_ID"
          }
        },
        {
          "name": "Get Course Modules",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/courses/YOUR_COURSE_ID/modules"
          }
        },
        {
          "name": "Get Labs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/labs"
          }
        },
        {
          "name": "Get Projects",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects"
          }
        },
        {
          "name": "Seed Database",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/seed"
          }
        }
      ]
    }
  ]
}
